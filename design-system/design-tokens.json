{
  "name": "主动健康管理系统设计令牌",
  "version": "1.0.0",
  "description": "从项目代码中提取出的核心设计令牌，包含白昼 SaaS 与暗色科技大屏双重风格。",
  "tokens": {
    "colors": {
      "light": {
        "background": "oklch(0.99 0.005 200)",
        "foreground": "oklch(0.2 0.03 220)",
        "card": "oklch(1 0 0)",
        "card-foreground": "oklch(0.2 0.03 220)",
        "primary": "oklch(0.55 0.13 195)",
        "primary-foreground": "oklch(0.99 0.005 200)",
        "secondary": "oklch(0.96 0.01 200)",
        "secondary-foreground": "oklch(0.25 0.04 220)",
        "muted": "oklch(0.96 0.01 200)",
        "muted-foreground": "oklch(0.5 0.02 230)",
        "accent": "oklch(0.94 0.04 195)",
        "accent-foreground": "oklch(0.25 0.06 200)",
        "border": "oklch(0.92 0.01 220)",
        "input": "oklch(0.92 0.01 220)",
        "ring": "oklch(0.55 0.13 195)"
      },
      "dark": {
        "background": "oklch(0.16 0.03 230)",
        "foreground": "oklch(0.97 0.01 200)",
        "card": "oklch(0.22 0.04 230)",
        "card-foreground": "oklch(0.97 0.01 200)",
        "primary": "oklch(0.78 0.18 195)",
        "primary-foreground": "oklch(0.18 0.04 230)",
        "secondary": "oklch(0.28 0.04 230)",
        "secondary-foreground": "oklch(0.97 0.01 200)",
        "muted": "oklch(0.28 0.04 230)",
        "muted-foreground": "oklch(0.72 0.04 220)",
        "accent": "oklch(0.32 0.06 200)",
        "accent-foreground": "oklch(0.97 0.01 200)",
        "border": "oklch(1 0 0 / 10%)",
        "input": "oklch(1 0 0 / 12%)",
        "ring": "oklch(0.78 0.18 195)"
      },
      "bigScreen": {
        "screen-bg": "oklch(0.18 0.04 230)",
        "screen-panel": "oklch(0.22 0.05 230)",
        "screen-border": "oklch(0.4 0.08 200 / 30%)",
        "screen-foreground": "oklch(0.97 0.01 200)",
        "screen-muted": "oklch(0.72 0.04 220)",
        "screen-accent": "oklch(0.78 0.18 195)"
      },
      "feedback": {
        "success": "oklch(0.7 0.16 155)",
        "warning": "oklch(0.78 0.16 75)",
        "danger": "oklch(0.62 0.23 22)",
        "info": "oklch(0.62 0.14 230)"
      },
      "charts": {
        "chart-1": "oklch(0.65 0.18 195)",
        "chart-2": "oklch(0.7 0.16 155)",
        "chart-3": "oklch(0.78 0.16 75)",
        "chart-4": "oklch(0.62 0.23 22)",
        "chart-5": "oklch(0.6 0.2 290)"
      }
    },
    "radius": {
      "base": "0.625rem",
      "sm": "calc(var(--radius) - 4px)",
      "md": "calc(var(--radius) - 2px)",
      "lg": "var(--radius)",
      "xl": "calc(var(--radius) + 4px)",
      "panel": "0.75rem"
    },
    "spacing": {
      "px": "1px",
      "0": "0px",
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "8": "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "16": "4rem"
    },
    "typography": {
      "features": {
        "tabular": "font-feature-settings: 'tnum' 1, 'ss01' 1"
      },
      "tracking": {
        "screen-title": "0.3em",
        "default": "normal"
      }
    }
  }
